<script>
// ══ CONFIG ══════════════════════════════════════════
var API_URL = 'https://script.google.com/macros/s/AKfycbwfywITzxf_sI5afFn9QTuzmi8V0ilhswJEhIUxTw4bbllSPDUNwRI7R-bE2cFnQSKZqg/exec';
var PORTAL_URL = 'https://script.google.com/macros/s/AKfycbyC_pVvrxkSSv2t7m86qp5msMlZwEeMd2KZX5sNWJ6CUp3XVgNY2RRPKcEMmRWdYt9eSw/exec';

var clientsData = [], paymentsData = [], historicalData = [];
var allClients = [];
var monthlyChart, packageChart, cashflowChart;
var venueSortCol = 'revenue', venueSortDir = 'desc', expandedVenue = null;

// ══ NAV ═════════════════════════════════════════════
var titles = {
    dashboard: 'Dashboard',
    cashflow: 'Cash Flow',
    venues: 'Venues',
    clients: 'Client Manager',
    portal: 'Planning Portal',
    booking: 'Booking Info'
};

function switchTab(tab, el) {
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
    document.getElementById('tab-' + tab).classList.add('active');
    el.classList.add('active');
    document.getElementById('topbarTitle').textContent = titles[tab];

    // Lazy-load portal iframe on first visit
    if (tab === 'portal') {
        var frame = document.getElementById('portalFrame');
        if (frame.src === 'about:blank') {
            frame.src = PORTAL_URL + '?action=portal';
        }
    }
}

// ══ UTILS ════════════════════════════════════════════
function parseAmount(v) {
    if (!v) return 0;
    return parseFloat(v.toString().replace(/[$,]/g, '')) || 0;
}

function parseDate(s) {
    if (!s) return null;
    try { return new Date(s); } catch(e) { return null; }
}

function fmt(n) {
    return new Intl.NumberFormat('en-US', { style:'currency', currency:'USD', minimumFractionDigits:0, maximumFractionDigits:0 }).format(n);
}

function fmtDate(d) {
    if (!d) return '—';
    return d.toLocaleDateString('en-US', { month:'short', day:'numeric', year:'numeric' });
}

// ══ DATA LOAD ════════════════════════════════════════
function loadData() {
    document.getElementById('dash-loader').style.display = 'flex';
    document.getElementById('dash-content').style.display = 'none';
    document.getElementById('dataStatus').textContent = '● loading...';

    Promise.all([
        fetch(API_URL + '?sheet=Clients'),
        fetch(API_URL + '?sheet=Payments'),
        fetch(API_URL + '?sheet=Historical')
    ])
    .then(rs => Promise.all(rs.map(r => r.json())))
    .then(function(data) {
        clientsData = data[0];
        paymentsData = data[1];
        historicalData = data[2];
        allClients = clientsData.slice();

        document.getElementById('dataStatus').innerHTML = '<span class="status-dot dot-green"></span> live';
        document.getElementById('dash-loader').style.display = 'none';
        document.getElementById('dash-content').style.display = 'block';

        buildDashboard();
        buildCashflow();
        buildVenues();
        buildClients();
    })
    .catch(function(err) {
        document.getElementById('dash-loader').innerHTML = '<div style="color:var(--red)">⚠ Error loading data: ' + err.message + '</div>';
        document.getElementById('dataStatus').innerHTML = '<span class="status-dot dot-red"></span> error';
    });
}

// ══ DASHBOARD ════════════════════════════════════════
function buildDashboard() {
    var now = new Date();
    var cy = now.getFullYear(), cm = now.getMonth();
    var months = ['January','February','March','April','May','June','July','August','September','October','November','December'];

    var outstanding = 0, dueThisMonth = 0, ytd = 0, thisMonth = 0, rev2026 = 0, cnt2026 = 0;

    clientsData.forEach(function(c) {
        var bal = parseAmount(c.BalanceDue);
        var total = parseAmount(c.TotalAmount);
        var d = parseDate(c['Wedding Date']);
        if (!d) return;
        if (d >= now || d.getFullYear() === 2026) outstanding += bal;
        if (d.getFullYear() === cy && d.getMonth() === cm) dueThisMonth += bal;
        if (d.getFullYear() === 2026 && total > 0) { rev2026 += total; cnt2026++; }
    });

    paymentsData.forEach(function(p) {
        var amt = parseAmount(p['Amount Paid']);
        var d = parseDate(p['Date Paid']);
        if (!d) return;
        if (d.getFullYear() === cy) { ytd += amt; if (d.getMonth() === cm) thisMonth += amt; }
    });

    var metrics = [
        { label: 'Due This Month', value: fmt(dueThisMonth), sub: months[cm] + ' ' + cy + ' weddings' },
        { label: 'Collected This Month', value: fmt(thisMonth), sub: 'Payments received' },
        { label: 'Outstanding Balance', value: fmt(outstanding), sub: 'Total remaining owed' },
        { label: 'Revenue YTD', value: fmt(ytd), sub: 'Collected in ' + cy },
        { label: '2026+ Avg Booking', value: fmt(cnt2026 > 0 ? rev2026/cnt2026 : 0), sub: 'Average deal size' },
        { label: '2026+ Bookings', value: cnt2026, sub: 'Future weddings confirmed' }
    ];

    var grid = document.getElementById('metricsGrid');
    grid.innerHTML = metrics.map(function(m) {
        return '<div class="metric"><div class="metric-label">' + m.label + '</div><div class="metric-value">' + m.value + '</div><div class="metric-sub">' + m.sub + '</div></div>';
    }).join('');

    renderUpcoming();
    renderMonthlyChart();
    renderPackageChart();
    renderYearBreakdown();
}

function renderUpcoming() {
    var now = new Date();
    var upcoming = clientsData.filter(function(c) {
        return parseAmount(c.BalanceDue) > 0 && parseDate(c['Wedding Date']) >= now;
    }).sort(function(a,b) { return parseDate(a['Wedding Date']) - parseDate(b['Wedding Date']); }).slice(0,8);

    var html = upcoming.map(function(c) {
        return '<div class="payment-row">' +
            '<div><div class="payment-name">' + (c.Name||'Unknown') + '</div><div class="payment-date">' + fmtDate(parseDate(c['Wedding Date'])) + '</div></div>' +
            '<div style="color:var(--muted2);font-size:12px">' + (c['Package Choice']||'—') + '</div>' +
            '<div style="color:var(--muted2);font-size:11px">' + (c['Add-Ons']||'None') + '</div>' +
            '<div class="payment-amount">' + fmt(parseAmount(c.BalanceDue)) + '</div>' +
            '</div>';
    }).join('');

    document.getElementById('upcomingPayments').innerHTML = html || '<p style="color:var(--muted);padding:20px;text-align:center;">No upcoming payments</p>';
}

function renderMonthlyChart() {
    var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    var now = new Date(); var cy = now.getFullYear(); var ly = cy - 1;
    var collected = months.map(function(){return 0;}), expected = months.map(function(){return 0;});

    paymentsData.forEach(function(p) {
        var amt = parseAmount(p['Amount Paid']);
        var d = parseDate(p['Date Paid']);
        if (d && d.getFullYear() === ly) collected[d.getMonth()] += amt;
    });
    historicalData.forEach(function(e) {
        var amt = parseAmount(e.Amount);
        var d = parseDate(e.Date);
        if (d && d.getFullYear() === ly) collected[d.getMonth()] += amt;
    });
    clientsData.forEach(function(c) {
        var total = parseAmount(c.TotalAmount);
        var d = parseDate(c['Wedding Date']);
        if (d && d.getFullYear() === cy) expected[d.getMonth()] += total;
    });

    var ctx = document.getElementById('monthlyChart').getContext('2d');
    if (monthlyChart) monthlyChart.destroy();
    monthlyChart = new Chart(ctx, {
        type: 'bar',
        data: { labels: months, datasets: [
            { label: 'Collected (' + ly + ')', data: collected, backgroundColor: 'rgba(200,169,110,0.7)', borderColor: 'rgba(200,169,110,1)', borderWidth: 1 },
            { label: 'Expected (' + cy + ')', data: expected, backgroundColor: 'rgba(92,142,224,0.5)', borderColor: 'rgba(92,142,224,1)', borderWidth: 1 }
        ]},
        options: {
            responsive: true, maintainAspectRatio: true,
            plugins: { legend: { labels: { color: '#9a9590', font: { family: 'DM Mono', size: 11 } } } },
            scales: {
                x: { ticks: { color: '#6b6861', font: { family: 'DM Mono' } }, grid: { color: 'rgba(255,255,255,0.04)' } },
                y: { ticks: { color: '#6b6861', font: { family: 'DM Mono' }, callback: function(v){return '$'+v.toLocaleString();} }, grid: { color: 'rgba(255,255,255,0.04)' } }
            }
        }
    });
}

function renderPackageChart() {
    var pkgs = {};
    clientsData.forEach(function(c) {
        var k = c['Package Choice'] || 'Unknown';
        pkgs[k] = (pkgs[k]||0) + parseAmount(c.TotalAmount);
    });
    var labels = Object.keys(pkgs), data = Object.values(pkgs);
    var ctx = document.getElementById('packageChart').getContext('2d');
    if (packageChart) packageChart.destroy();
    packageChart = new Chart(ctx, {
        type: 'doughnut',
        data: { labels: labels, datasets: [{ data: data,
            backgroundColor: ['rgba(200,169,110,0.8)','rgba(92,142,224,0.8)','rgba(76,175,125,0.8)','rgba(224,92,92,0.8)','rgba(180,100,200,0.8)'],
            borderColor: '#111317', borderWidth: 2 }]},
        options: {
            responsive: true, maintainAspectRatio: true,
            plugins: {
                legend: { position: 'bottom', labels: { color: '#9a9590', font: { family: 'DM Mono', size: 11 }, padding: 14 } },
                tooltip: { callbacks: { label: function(c){ return c.label + ': ' + fmt(c.parsed); } } }
            }
        }
    });
}

function renderYearBreakdown() {
    var monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];
    var stats = {};

    function addToStats(year, month, revenue) {
        if (!stats[year]) stats[year] = { count:0, revenue:0, months:{} };
        if (!stats[year].months[month]) stats[year].months[month] = { count:0, revenue:0 };
        stats[year].count++; stats[year].revenue += revenue;
        stats[year].months[month].count++; stats[year].months[month].revenue += revenue;
    }

    clientsData.forEach(function(c) {
        var d = parseDate(c['Wedding Date']); var total = parseAmount(c.TotalAmount);
        if (d && total > 0) addToStats(d.getFullYear(), d.getMonth(), total);
    });
    historicalData.forEach(function(e) {
        var d = parseDate(e.Date); var amt = parseAmount(e.Amount);
        if (d && amt > 0) addToStats(d.getFullYear(), d.getMonth(), amt);
    });

    var years = Object.keys(stats).sort(function(a,b){return b-a;});
    var html = '<table class="data-table"><thead><tr><th>Year</th><th>Bookings</th><th>Revenue</th><th>Avg/Booking</th></tr></thead><tbody>';

    years.forEach(function(year) {
        var s = stats[year];
        html += '<tr class="year-row-expand" onclick="toggleYear(\'' + year + '\')" id="yr-' + year + '">'
            + '<td><span id="yi-' + year + '" style="margin-right:8px;font-size:10px">▶</span><strong>' + year + '</strong></td>'
            + '<td>' + s.count + '</td>'
            + '<td style="color:var(--accent)">' + fmt(s.revenue) + '</td>'
            + '<td>' + fmt(s.revenue/s.count) + '</td>'
            + '</tr>';

        html += '<tr id="ym-' + year + '" class="months-hidden"><td colspan="4" style="padding:0">';
        html += '<div class="months-inner"><div class="month-mini-grid">';
        Object.keys(s.months).sort(function(a,b){return a-b;}).forEach(function(mi) {
            var m = s.months[mi];
            html += '<div class="month-chip"><div class="mname">' + monthNames[mi] + '</div>'
                + '<div class="mamount">' + fmt(m.revenue) + '</div>'
                + '<div class="mcount">' + m.count + ' booking' + (m.count>1?'s':'') + '</div></div>';
        });
        html += '</div></div></td></tr>';
    });
    html += '</tbody></table>';
    document.getElementById('yearBreakdown').innerHTML = html;
}

window.toggleYear = function(y) {
    var row = document.getElementById('ym-' + y);
    var icon = document.getElementById('yi-' + y);
    var open = row.classList.contains('months-open');
    row.className = open ? 'months-hidden' : 'months-open';
    icon.textContent = open ? '▶' : '▼';
};

// ══ CASH FLOW ════════════════════════════════════════
function buildCashflow() {
    var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    var paid = months.map(function(){return 0;}), owed = months.map(function(){return 0;});

    clientsData.forEach(function(c) {
        var d = parseDate(c['Wedding Date']);
        if (d && d.getFullYear() === 2026) {
            paid[d.getMonth()] += parseAmount(c.AmountPaid);
            owed[d.getMonth()] += parseAmount(c.BalanceDue);
        }
    });

    var ctx = document.getElementById('cashflowChart').getContext('2d');
    if (cashflowChart) cashflowChart.destroy();
    cashflowChart = new Chart(ctx, {
        type: 'bar',
        data: { labels: months, datasets: [
            { label: 'Paid', data: paid, backgroundColor: 'rgba(76,175,125,0.75)', borderColor: 'rgba(76,175,125,1)', borderWidth: 1 },
            { label: 'Outstanding', data: owed, backgroundColor: 'rgba(224,92,92,0.55)', borderColor: 'rgba(224,92,92,1)', borderWidth: 1 }
        ]},
        options: {
            responsive: true, maintainAspectRatio: true,
            plugins: { legend: { labels: { color: '#9a9590', font: { family: 'DM Mono', size: 11 } } } },
            scales: {
                x: { stacked: true, ticks: { color: '#6b6861', font: { family: 'DM Mono' } }, grid: { color: 'rgba(255,255,255,0.04)' } },
                y: { stacked: true, ticks: { color: '#6b6861', font: { family: 'DM Mono' }, callback: function(v){return '$'+v.toLocaleString();} }, grid: { color: 'rgba(255,255,255,0.04)' } }
            }
        }
    });

    // Outstanding table
    var rows = clientsData
        .filter(function(c){ return parseAmount(c.BalanceDue) > 0; })
        .sort(function(a,b){ return (parseDate(a['Wedding Date'])||0) - (parseDate(b['Wedding Date'])||0); });

    var tbody = document.getElementById('outstandingBody');
    tbody.innerHTML = rows.map(function(c) {
        var bal = parseAmount(c.BalanceDue);
        var total = parseAmount(c.TotalAmount);
        var pct = total > 0 ? Math.round((total-bal)/total*100) : 0;
        return '<tr>'
            + '<td>' + (c.Name||'—') + '</td>'
            + '<td class="mono">' + fmtDate(parseDate(c['Wedding Date'])) + '</td>'
            + '<td>' + (c['Package Choice']||'—') + '</td>'
            + '<td class="mono">' + fmt(total) + '</td>'
            + '<td class="mono" style="color:var(--green)">' + fmt(total-bal) + ' <span style="color:var(--muted);font-size:10px">(' + pct + '%)</span></td>'
            + '<td class="mono" style="color:var(--red)">' + fmt(bal) + '</td>'
            + '</tr>';
    }).join('');
}

// ══ VENUES ═══════════════════════════════════════════
function buildVenues() {
    var venueMap = {};

    function addVenue(venue, amount, date, name) {
        venue = (venue||'').toString().trim();
        if (!venue || !amount) return;
        if (!venueMap[venue]) venueMap[venue] = { revenue:0, count:0, lastDate:null, events:[] };
        venueMap[venue].revenue += amount;
        venueMap[venue].count++;
        venueMap[venue].events.push({ date:date, name:name, amount:amount });
        if (!venueMap[venue].lastDate || date > venueMap[venue].lastDate) venueMap[venue].lastDate = date;
    }

    clientsData.forEach(function(c) {
        addVenue(c.Location, parseAmount(c.TotalAmount), parseDate(c['Wedding Date']), c.Name||'Unknown');
    });
    historicalData.forEach(function(e) {
        addVenue(e.Location, parseAmount(e.Amount), parseDate(e.Date), e.Who||'Unknown');
    });

    window._venueMap = venueMap;
    renderVenueTable();
}

window.sortVenue = function(col) {
    if (venueSortCol === col) venueSortDir = venueSortDir === 'asc' ? 'desc' : 'asc';
    else { venueSortCol = col; venueSortDir = 'desc'; }
    expandedVenue = null;
    renderVenueTable();
};

function renderVenueTable() {
    var vm = window._venueMap || {};
    var arr = Object.entries(vm).map(function(e) { return Object.assign({ venue: e[0] }, e[1]); });
    arr.sort(function(a,b) {
        var av = a[venueSortCol], bv = b[venueSortCol];
        if (venueSortCol === 'lastDate') { av = av ? av.getTime() : 0; bv = bv ? bv.getTime() : 0; }
        return venueSortDir === 'asc' ? (av > bv ? 1 : -1) : (av < bv ? 1 : -1);
    });

    var html = arr.map(function(v) {
        var isOpen = expandedVenue === v.venue;
        var rows = '<tr style="cursor:pointer" onclick="toggleVenueRow(\'' + v.venue.replace(/'/g,"\\'") + '\')">'
            + '<td><span style="margin-right:8px;font-size:10px;color:var(--muted)">' + (isOpen?'▼':'▶') + '</span>' + v.venue + '</td>'
            + '<td style="color:var(--accent);font-family:\'Instrument Serif\',serif;font-size:16px">' + fmt(v.revenue) + '</td>'
            + '<td>' + v.count + '</td>'
            + '<td class="mono" style="font-size:11px">' + fmtDate(v.lastDate) + '</td>'
            + '</tr>';
        if (isOpen) {
            var sortedEvts = v.events.slice().sort(function(a,b){return b.date-a.date;});
            rows += '<tr><td colspan="4" style="padding:0"><div style="background:var(--surface2);padding:16px 20px;border-top:1px solid var(--border)">'
                + '<table class="venue-sub-table"><thead><tr style="color:var(--muted);font-size:10px;letter-spacing:1px">'
                + '<td>DATE</td><td>CLIENT</td><td style="text-align:right">AMOUNT</td></tr></thead><tbody>'
                + sortedEvts.map(function(e) {
                    return '<tr><td>' + fmtDate(e.date) + '</td><td>' + e.name + '</td><td style="text-align:right;color:var(--accent)">' + fmt(e.amount) + '</td></tr>';
                }).join('')
                + '</tbody></table></div></td></tr>';
        }
        return rows;
    }).join('');

    document.getElementById('venueBody').innerHTML = html;
}

window.toggleVenueRow = function(venue) {
    expandedVenue = expandedVenue === venue ? null : venue;
    renderVenueTable();
};

// ══ CLIENTS ══════════════════════════════════════════
function buildClients() {
    renderClientsTable(clientsData);
}

function filterClients() {
    var q = document.getElementById('clientSearch').value.toLowerCase();
    var yr = document.getElementById('yearFilter').value;
    var bal = document.getElementById('balanceFilter').value;

    var filtered = clientsData.filter(function(c) {
        var name = (c.Name||'').toLowerCase();
        var venue = (c.Location||'').toLowerCase();
        var pkg = (c['Package Choice']||'').toLowerCase();
        var matchQ = !q || name.includes(q) || venue.includes(q) || pkg.includes(q);
        
        var d = parseDate(c['Wedding Date']);
        var matchYr = !yr || (d && d.getFullYear().toString() === yr);
        
        var balance = parseAmount(c.BalanceDue);
        var matchBal = !bal || (bal==='outstanding' && balance>0) || (bal==='paid' && balance<=0);

        return matchQ && matchYr && matchBal;
    });

    document.getElementById('clientCount').textContent = filtered.length + ' client' + (filtered.length!==1?'s':'') + ' shown (' + clientsData.length + ' total)';
    renderClientsTable(filtered);
}

var expandedClient = null;

function renderClientsTable(data) {
    document.getElementById('clientCount').textContent = data.length + ' client' + (data.length!==1?'s':'') + ' shown (' + clientsData.length + ' total)';

    var html = data.map(function(c, i) {
        var bal = parseAmount(c.BalanceDue);
        var total = parseAmount(c.TotalAmount);
        var d = parseDate(c['Wedding Date']);
        var statusBadge = bal <= 0 
            ? '<span class="badge badge-green">Paid</span>'
            : '<span class="badge badge-amber">Balance Due</span>';

        var key = c.Name + '_' + (d ? d.getTime() : i);
        var isOpen = expandedClient === key;

        var row = '<tr>'
            + '<td><button class="expand-btn" onclick="toggleClient(\'' + key.replace(/'/g,"\\'") + '\')">' + (isOpen?'▼':'▶') + '</button></td>'
            + '<td style="font-weight:500">' + (c.Name||'—') + '</td>'
            + '<td class="mono" style="font-size:11px">' + fmtDate(d) + '</td>'
            + '<td style="color:var(--muted2)">' + (c.Location||'—') + '</td>'
            + '<td><span class="badge badge-blue">' + (c['Package Choice']||'—') + '</span></td>'
            + '<td class="mono">' + fmt(total) + '</td>'
            + '<td class="mono" style="color:' + (bal>0?'var(--red)':'var(--green)') + '">' + (bal>0?fmt(bal):'—') + '</td>'
            + '<td>' + statusBadge + '</td>'
            + '</tr>';

        if (isOpen) {
            var fields = [
                ['Total Amount', fmt(total)],
                ['Amount Paid', fmt(parseAmount(c.AmountPaid))],
                ['Balance Due', fmt(bal)],
                ['Package', c['Package Choice']||'—'],
                ['Add-Ons', c['Add-Ons']||'None'],
                ['Location', c.Location||'—'],
                ['Wedding Date', fmtDate(d)],
                ['Email', c.Email||'—'],
                ['Phone', c.Phone||'—'],
                ['Notes', c.Notes||'—']
            ];
            row += '<tr><td colspan="8" style="padding:0"><div class="expanded-content">'
                + '<div class="detail-grid">'
                + fields.map(function(f) {
                    return '<div class="detail-item"><label>' + f[0] + '</label><span>' + f[1] + '</span></div>';
                }).join('')
                + '</div></div></td></tr>';
        }

        return row;
    }).join('');

    document.getElementById('clientsBody').innerHTML = html || '<tr><td colspan="8" style="text-align:center;padding:40px;color:var(--muted)">No clients match your filters</td></tr>';
}

window.toggleClient = function(key) {
    expandedClient = expandedClient === key ? null : key;
    filterClients();
};

// ══ EXPORT ═══════════════════════════════════════════
function exportCSV() {
    if (!clientsData || clientsData.length === 0) { alert('No data loaded yet. Please wait for data to load first.'); return; }
    var cols = ['Name', 'Wedding Date', 'Location', 'Package Choice', 'Add-Ons', 'TotalAmount', 'AmountPaid', 'BalanceDue', 'Email', 'Phone', 'Notes'];
    var rows = [cols.join(',')];
    clientsData.forEach(function(c) {
        rows.push(cols.map(function(k) {
            var v = (c[k]||'').toString().replace(/"/g,'""');
            return v.includes(',') ? '"' + v + '"' : v;
        }).join(','));
    });
    var blob = new Blob([rows.join('\n')], { type: 'text/csv' });
    var url = URL.createObjectURL(blob);
    var a = document.createElement('a');
    a.href = url; a.download = 'djcole-clients-' + new Date().toISOString().slice(0,10) + '.csv';
    a.click(); URL.revokeObjectURL(url);
}

// ══ BOOT ═════════════════════════════════════════════
loadData();
</script>
</body>
