<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DJ Cole — Admin Console</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #0a0c0f;
            --surface: #111317;
            --surface2: #181b20;
            --border: rgba(255,255,255,0.07);
            --border2: rgba(255,255,255,0.12);
            --accent: #c8a96e;
            --accent2: #e8c98e;
            --text: #e8e6e0;
            --muted: #6b6861;
            --muted2: #9a9590;
            --green: #4caf7d;
            --red: #e05c5c;
            --blue: #5c8ee0;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'DM Mono', monospace;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            font-size: 13px;
        }

        /* ── SIDEBAR ─────────────────────────────── */
        .layout {
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 220px;
            min-height: 100vh;
            background: var(--surface);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            position: fixed;
            top: 0; left: 0;
            z-index: 100;
        }

        .sidebar-logo {
            padding: 28px 24px 20px;
            border-bottom: 1px solid var(--border);
        }

        .sidebar-logo .name {
            font-family: 'Instrument Serif', serif;
            font-size: 22px;
            color: var(--accent);
            line-height: 1;
        }

        .sidebar-logo .sub {
            font-size: 9px;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: var(--muted);
            margin-top: 4px;
        }

        .sidebar-nav {
            padding: 16px 12px;
            flex: 1;
        }

        .nav-section-label {
            font-size: 9px;
            letter-spacing: 2.5px;
            text-transform: uppercase;
            color: var(--muted);
            padding: 0 12px;
            margin-bottom: 8px;
            margin-top: 16px;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 9px 12px;
            border-radius: 6px;
            cursor: pointer;
            color: var(--muted2);
            font-size: 12px;
            transition: all 0.15s;
            margin-bottom: 2px;
            border: 1px solid transparent;
            text-decoration: none;
        }

        .nav-item:hover {
            background: var(--surface2);
            color: var(--text);
        }

        .nav-item.active {
            background: rgba(200, 169, 110, 0.1);
            color: var(--accent);
            border-color: rgba(200, 169, 110, 0.2);
        }

        .nav-icon {
            width: 16px;
            text-align: center;
            font-size: 14px;
            flex-shrink: 0;
        }

        .sidebar-footer {
            padding: 16px 24px;
            border-top: 1px solid var(--border);
            font-size: 10px;
            color: var(--muted);
        }

        /* ── MAIN CONTENT ─────────────────────────── */
        .main {
            margin-left: 220px;
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .topbar {
            height: 56px;
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 32px;
            position: sticky;
            top: 0;
            z-index: 50;
        }

        .topbar-title {
            font-family: 'Instrument Serif', serif;
            font-size: 18px;
            color: var(--text);
        }

        .topbar-actions {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 7px 14px;
            border-radius: 5px;
            font-family: 'DM Mono', monospace;
            font-size: 11px;
            cursor: pointer;
            transition: all 0.15s;
            border: 1px solid var(--border2);
            background: var(--surface2);
            color: var(--muted2);
        }

        .btn:hover { color: var(--text); border-color: var(--accent); }

        .btn-accent {
            background: var(--accent);
            color: var(--bg);
            border-color: var(--accent);
        }

        .btn-accent:hover { background: var(--accent2); color: var(--bg); border-color: var(--accent2); }

        .content {
            padding: 32px;
            flex: 1;
        }

        /* ── TAB PANELS ───────────────────────────── */
        .tab-panel { display: none; }
        .tab-panel.active { display: block; }

        /* ── CARDS ────────────────────────────────── */
        .card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 24px;
            margin-bottom: 20px;
        }

        .card-title {
            font-family: 'Instrument Serif', serif;
            font-size: 16px;
            color: var(--text);
            margin-bottom: 4px;
        }

        .card-sub {
            font-size: 10px;
            color: var(--muted);
            letter-spacing: 1px;
            text-transform: uppercase;
            margin-bottom: 20px;
        }

        /* ── METRICS ──────────────────────────────── */
        .metrics-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 16px;
            margin-bottom: 24px;
        }

        .metric {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 20px;
            position: relative;
            overflow: hidden;
        }

        .metric::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 2px;
            background: linear-gradient(90deg, var(--accent), transparent);
        }

        .metric-label {
            font-size: 9px;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--muted);
            margin-bottom: 10px;
        }

        .metric-value {
            font-family: 'Instrument Serif', serif;
            font-size: 28px;
            color: var(--accent);
            line-height: 1;
        }

        .metric-sub {
            font-size: 10px;
            color: var(--muted);
            margin-top: 6px;
        }

        /* ── CHART CARDS ──────────────────────────── */
        .charts-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 20px;
        }

        .chart-wrap {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 24px;
        }

        .chart-wrap canvas {
            max-height: 260px;
        }

        /* ── TABLE ────────────────────────────────── */
        .data-table {
            width: 100%;
            border-collapse: collapse;
        }

        .data-table th {
            text-align: left;
            font-size: 9px;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--muted);
            padding: 10px 14px;
            border-bottom: 1px solid var(--border);
            cursor: pointer;
            user-select: none;
        }

        .data-table th:hover { color: var(--accent); }

        .data-table td {
            padding: 12px 14px;
            border-bottom: 1px solid rgba(255,255,255,0.04);
            color: var(--text);
            font-size: 12px;
        }

        .data-table tr:hover td { background: rgba(255,255,255,0.02); }

        .data-table td.mono { font-family: 'DM Mono', monospace; }

        .badge {
            display: inline-flex;
            align-items: center;
            padding: 2px 8px;
            border-radius: 20px;
            font-size: 10px;
            font-weight: 500;
        }

        .badge-green { background: rgba(76,175,125,0.15); color: var(--green); }
        .badge-amber { background: rgba(200,169,110,0.15); color: var(--accent); }
        .badge-red { background: rgba(224,92,92,0.15); color: var(--red); }
        .badge-blue { background: rgba(92,142,224,0.15); color: var(--blue); }

        /* ── LOADING ──────────────────────────────── */
        .loader {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 80px 0;
            color: var(--muted);
        }

        .spinner {
            width: 32px; height: 32px;
            border: 2px solid var(--border);
            border-top-color: var(--accent);
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
            margin-bottom: 16px;
        }

        @keyframes spin { to { transform: rotate(360deg); } }

        /* ── UPCOMING PAYMENTS ────────────────────── */
        .payment-row {
            display: grid;
            grid-template-columns: 2fr 1.5fr 1.5fr 1fr;
            gap: 16px;
            align-items: center;
            padding: 14px;
            border-radius: 8px;
            background: var(--surface2);
            margin-bottom: 8px;
            border: 1px solid var(--border);
        }

        .payment-row:last-child { margin-bottom: 0; }

        .payment-name {
            font-weight: 500;
            color: var(--text);
            font-size: 13px;
        }

        .payment-date {
            font-size: 11px;
            color: var(--muted2);
            margin-top: 2px;
        }

        .payment-amount {
            font-family: 'Instrument Serif', serif;
            font-size: 18px;
            color: var(--accent);
            text-align: right;
        }

        /* ── CLIENTS ADMIN ────────────────────────── */
        .clients-toolbar {
            display: flex;
            gap: 12px;
            margin-bottom: 20px;
            align-items: center;
        }

        .search-input {
            flex: 1;
            background: var(--surface2);
            border: 1px solid var(--border2);
            border-radius: 6px;
            padding: 8px 14px;
            color: var(--text);
            font-family: 'DM Mono', monospace;
            font-size: 12px;
            outline: none;
        }

        .search-input:focus { border-color: var(--accent); }
        .search-input::placeholder { color: var(--muted); }

        .filter-select {
            background: var(--surface2);
            border: 1px solid var(--border2);
            border-radius: 6px;
            padding: 8px 14px;
            color: var(--muted2);
            font-family: 'DM Mono', monospace;
            font-size: 12px;
            outline: none;
            cursor: pointer;
        }

        .filter-select:focus { border-color: var(--accent); }

        /* ── EXPANDABLE ROW ───────────────────────── */
        .expand-btn {
            background: none;
            border: none;
            color: var(--muted);
            cursor: pointer;
            font-size: 10px;
            padding: 2px 6px;
            border-radius: 3px;
            transition: color 0.15s;
        }

        .expand-btn:hover { color: var(--accent); }

        .expanded-row {
            display: none;
        }

        .expanded-row.open {
            display: table-row;
        }

        .expanded-content {
            background: var(--surface2);
            padding: 16px 20px;
            border-top: 1px solid var(--border);
        }

        .detail-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 12px;
            margin-bottom: 12px;
        }

        .detail-item label {
            font-size: 9px;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--muted);
            display: block;
            margin-bottom: 3px;
        }

        .detail-item span {
            font-size: 12px;
            color: var(--text);
        }

        /* ── BOOKING EMBED ────────────────────────── */
        .booking-frame-wrap {
            border-radius: 10px;
            overflow: hidden;
            border: 1px solid var(--border);
            background: #fff;
        }

        /* ── SECTION HEADER ───────────────────────── */
        .section-header {
            margin-bottom: 24px;
        }

        .section-header h2 {
            font-family: 'Instrument Serif', serif;
            font-size: 26px;
            color: var(--text);
        }

        .section-header p {
            color: var(--muted);
            font-size: 11px;
            margin-top: 4px;
        }

        /* ── YEAR TABLE ───────────────────────────── */
        .year-row-expand {
            cursor: pointer;
        }

        .year-row-expand:hover td { background: rgba(200,169,110,0.05); }

        .months-hidden { display: none; }
        .months-open { display: table-row; }

        .months-inner {
            padding: 0 14px 14px 40px;
        }

        .month-mini-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
            gap: 8px;
            padding: 12px 0;
        }

        .month-chip {
            background: var(--bg);
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 10px 12px;
            font-size: 11px;
        }

        .month-chip .mname { color: var(--muted2); margin-bottom: 3px; }
        .month-chip .mamount { color: var(--accent); font-family: 'Instrument Serif', serif; font-size: 16px; }
        .month-chip .mcount { color: var(--muted); font-size: 10px; }

        /* ── VENUE TABLE ─────────────────────────── */
        .venue-sub-table { width: 100%; }
        .venue-sub-table td { font-size: 11px; padding: 6px 10px; border-bottom: 1px solid rgba(255,255,255,0.03); color: var(--muted2); }

        /* ── IFRAME OVERLAY (client portal) ─────── */
        .portal-embed {
            width: 100%;
            height: 800px;
            border: none;
            border-radius: 10px;
            background: #fff;
        }

        /* ── STATUS INDICATOR ────────────────────── */
        .status-dot {
            display: inline-block;
            width: 7px; height: 7px;
            border-radius: 50%;
            margin-right: 6px;
        }

        .dot-green { background: var(--green); box-shadow: 0 0 6px rgba(76,175,125,0.5); }
        .dot-amber { background: var(--accent); box-shadow: 0 0 6px rgba(200,169,110,0.5); }
        .dot-red { background: var(--red); }

        /* ── EXPORT BAR ──────────────────────────── */
        .export-bar {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 16px;
            background: rgba(200,169,110,0.06);
            border: 1px solid rgba(200,169,110,0.15);
            border-radius: 8px;
            margin-bottom: 20px;
        }

        .export-label { font-size: 11px; color: var(--muted2); flex: 1; }

        /* ── SCROLLBAR ───────────────────────────── */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 3px; }

        /* ── RESPONSIVE ──────────────────────────── */
        @media (max-width: 900px) {
            .sidebar { width: 60px; }
            .sidebar-logo .name, .sidebar-logo .sub, .nav-item span, .nav-section-label { display: none; }
            .nav-item { justify-content: center; padding: 10px; }
            .main { margin-left: 60px; }
            .charts-row { grid-template-columns: 1fr; }
            .payment-row { grid-template-columns: 1fr 1fr; }
        }
    </style>
</head>
<body>
<div class="layout">

<!-- ══ SIDEBAR ══════════════════════════════════════ -->
<aside class="sidebar">
    <div class="sidebar-logo">
        <div class="name">DJ Cole</div>
        <div class="sub">Admin Console</div>
    </div>
    <nav class="sidebar-nav">
        <div class="nav-section-label">Analytics</div>
        <div class="nav-item active" onclick="switchTab('dashboard', this)">
            <span class="nav-icon">📊</span>
            <span>Dashboard</span>
        </div>
        <div class="nav-item" onclick="switchTab('cashflow', this)">
            <span class="nav-icon">💰</span>
            <span>Cash Flow</span>
        </div>
        <div class="nav-item" onclick="switchTab('venues', this)">
            <span class="nav-icon">📍</span>
            <span>Venues</span>
        </div>

        <div class="nav-section-label">Clients</div>
        <div class="nav-item" onclick="switchTab('clients', this)">
            <span class="nav-icon">👥</span>
            <span>Client Manager</span>
        </div>
        <div class="nav-item" onclick="switchTab('portal', this)">
            <span class="nav-icon">📋</span>
            <span>Planning Portal</span>
        </div>

        <div class="nav-section-label">Business</div>
        <div class="nav-item" onclick="switchTab('booking', this)">
            <span class="nav-icon">📅</span>
            <span>Booking Info</span>
        </div>
    </nav>
    <div class="sidebar-footer">
        <div id="dataStatus">— offline</div>
    </div>
</aside>

<!-- ══ MAIN ══════════════════════════════════════════ -->
<main class="main">
    <div class="topbar">
        <div class="topbar-title" id="topbarTitle">Dashboard</div>
        <div class="topbar-actions">
            <button class="btn" onclick="loadData()">⟳ Refresh</button>
            <button class="btn btn-accent" onclick="exportCSV()">↓ Export CSV</button>
        </div>
    </div>

    <div class="content">

        <!-- ── DASHBOARD TAB ─────────────────────── -->
        <div class="tab-panel active" id="tab-dashboard">
            <div class="section-header">
                <h2>Overview</h2>
                <p>Real-time snapshot of your business</p>
            </div>

            <div id="dash-loader" class="loader">
                <div class="spinner"></div>
                <div>Loading your data...</div>
            </div>
            <div id="dash-content" style="display:none">
                <div class="metrics-grid" id="metricsGrid"></div>

                <div class="card">
                    <div class="card-title">Next Payments Due</div>
                    <div class="card-sub">Upcoming balances sorted by wedding date</div>
                    <div id="upcomingPayments"></div>
                </div>

                <div class="charts-row">
                    <div class="chart-wrap">
                        <div class="card-title" style="margin-bottom:4px">Monthly Revenue</div>
                        <div class="card-sub">Collected vs expected by month</div>
                        <canvas id="monthlyChart"></canvas>
                    </div>
                    <div class="chart-wrap">
                        <div class="card-title" style="margin-bottom:4px">Package Distribution</div>
                        <div class="card-sub">Revenue by package type</div>
                        <canvas id="packageChart"></canvas>
                    </div>
                </div>

                <div class="card">
                    <div class="card-title">Year-over-Year Performance</div>
                    <div class="card-sub">Click a row to expand monthly breakdown</div>
                    <div id="yearBreakdown"></div>
                </div>
            </div>
        </div>

        <!-- ── CASH FLOW TAB ─────────────────────── -->
        <div class="tab-panel" id="tab-cashflow">
            <div class="section-header">
                <h2>Cash Flow</h2>
                <p>Collected vs outstanding by month</p>
            </div>
            <div class="chart-wrap" style="margin-bottom:20px">
                <div class="card-title" style="margin-bottom:4px">2026 Cash Flow Projection</div>
                <div class="card-sub">Stacked: paid in green, outstanding in red</div>
                <canvas id="cashflowChart" style="max-height:320px"></canvas>
            </div>
            <div class="card">
                <div class="card-title">Outstanding by Client</div>
                <div class="card-sub">All clients with a remaining balance</div>
                <table class="data-table" id="outstandingTable">
                    <thead><tr>
                        <th>Client</th>
                        <th>Wedding Date</th>
                        <th>Package</th>
                        <th>Total</th>
                        <th>Paid</th>
                        <th>Balance</th>
                    </tr></thead>
                    <tbody id="outstandingBody"></tbody>
                </table>
            </div>
        </div>

        <!-- ── VENUES TAB ─────────────────────────── -->
        <div class="tab-panel" id="tab-venues">
            <div class="section-header">
                <h2>Venues</h2>
                <p>Revenue and history by location</p>
            </div>
            <div class="card">
                <div class="card-title">All Venues</div>
                <div class="card-sub">Click a venue to see event history</div>
                <table class="data-table" id="venueTable">
                    <thead><tr>
                        <th onclick="sortVenue('venue')">Venue ⇅</th>
                        <th onclick="sortVenue('revenue')">Revenue ⇅</th>
                        <th onclick="sortVenue('count')">Events ⇅</th>
                        <th onclick="sortVenue('lastDate')">Last Event ⇅</th>
                    </tr></thead>
                    <tbody id="venueBody"></tbody>
                </table>
            </div>
        </div>

        <!-- ── CLIENT MANAGER TAB ─────────────────── -->
        <div class="tab-panel" id="tab-clients">
            <div class="section-header">
                <h2>Client Manager</h2>
                <p>Admin view of all client data</p>
            </div>

            <div class="export-bar">
                <span class="export-label" id="clientCount">Loading clients...</span>
                <button class="btn btn-accent" onclick="exportCSV()">↓ Export All as CSV</button>
            </div>

            <div class="clients-toolbar">
                <input class="search-input" type="text" placeholder="Search by name, venue, package..." id="clientSearch" oninput="filterClients()">
                <select class="filter-select" id="yearFilter" onchange="filterClients()">
                    <option value="">All Years</option>
                    <option value="2024">2024</option>
                    <option value="2025">2025</option>
                    <option value="2026">2026</option>
                    <option value="2027">2027</option>
                </select>
                <select class="filter-select" id="balanceFilter" onchange="filterClients()">
                    <option value="">All</option>
                    <option value="outstanding">Has Balance</option>
                    <option value="paid">Paid in Full</option>
                </select>
            </div>

            <div class="card" style="padding:0; overflow:hidden">
                <table class="data-table" id="clientsTable">
                    <thead><tr>
                        <th></th>
                        <th>Name</th>
                        <th>Wedding Date</th>
                        <th>Venue</th>
                        <th>Package</th>
                        <th>Total</th>
                        <th>Balance</th>
                        <th>Status</th>
                    </tr></thead>
                    <tbody id="clientsBody"></tbody>
                </table>
            </div>
        </div>

        <!-- ── PLANNING PORTAL TAB ────────────────── -->
        <div class="tab-panel" id="tab-portal">
            <div class="section-header">
                <h2>Planning Portal</h2>
                <p>Client-facing wedding planning form</p>
            </div>
            <div class="booking-frame-wrap">
                <iframe class="portal-embed" 
                    src="about:blank" 
                    id="portalFrame"
                    title="DJ Cole Wedding Planning Portal">
                </iframe>
            </div>
            <p style="font-size:10px; color:var(--muted); margin-top:12px; text-align:center;">
                This is the client-facing portal. Clients access it directly via their unique access code.
            </p>
        </div>

        <!-- ── BOOKING TAB ────────────────────────── -->
        <div class="tab-panel" id="tab-booking">
            <div class="section-header">
                <h2>Booking Information</h2>
                <p>Pricing packet — the client-facing booking info page</p>
            </div>
            <div class="booking-frame-wrap" style="background: radial-gradient(#b6b6b6 0%, #152f3f 80%); padding:20px; border-radius:10px;">
                <div style="max-width:900px; margin:0 auto; background:white; border-radius:8px; overflow:hidden;">
                    <div style="background:#b6b6b6; padding:20px; text-align:center;">
